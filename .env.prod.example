# ── Produktion — Werte UNBEDINGT anpassen! ───────────────────────────────────
# Generieren mit: openssl rand -hex 20  bzw.  openssl rand -hex 32

DB_PASSWORD=HIER_SICHERES_PASSWORT_EINSETZEN

SECRET_KEY=HIER_LANGEN_ZUFAELLIGEN_SCHLUESSEL_EINSETZEN_MIN_32_ZEICHEN

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Nur die echte Domain eintragen — kein Wildcard in Produktion!
# Beispiel: CORS_ORIGINS=http://192.168.1.100:7842
CORS_ORIGINS=http://DEINE-SERVER-IP:7842

# Hero CRM Integration
HERO_API_URL=https://login.hero-software.de/api/external/v7/graphql
HERO_API_TOKEN=Bearer DEIN_HERO_API_TOKEN
HERO_PARTNER_ID=DEINE_HERO_PARTNER_ID
