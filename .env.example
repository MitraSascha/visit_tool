# card-vault Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus

# Datenbank-Passwort (sicheres Passwort wählen)
DB_PASSWORD=change_me_secure_password

# JWT Secret Key (mindestens 32 zufällige Zeichen)
# Generieren mit: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Token-Laufzeiten (optional, defaults werden verwendet)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Hero CRM Integration
HERO_API_URL=https://login.hero-software.de/api/external/v7/graphql
HERO_API_TOKEN=Bearer DEIN_HERO_API_TOKEN
HERO_PARTNER_ID=DEINE_HERO_PARTNER_ID
